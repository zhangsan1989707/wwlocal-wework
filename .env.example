# 数据库配置
DB_PASSWORD=your_db_password_here

# 服务端口配置（可选，默认值已在 docker-compose.yml 中设置）
MYSQL_PORT=3307
BACKEND_PORT=3010
FRONTEND_PORT=5173

# 政务微信配置
WEWORK_BASE_URL=
WEWORK_CORPID=your_corpid_here
WEWORK_SECRET=your_secret_here
WEWORK_CONTACT_SECRET=your_contact_secret_here
WEWORK_INSECURE_SKIP_VERIFY=false

# 认证配置
AUTH_USERNAME=admin
AUTH_PASSWORD=your_auth_password_here
JWT_SECRET=your_jwt_secret_here

# 密钥加密密钥（可选）
KEY_ENCRYPT_KEY=
