# 复制为 .env 并填入实际值
DB_PASSWORD=your_db_password
WEWORK_BASE_URL=https://your-wework-api-host:port
WEWORK_CORPID=your_corp_id
WEWORK_SECRET=your_secret
WEWORK_CONTACT_SECRET=your_contact_secret
WEWORK_INSECURE_SKIP_VERIFY=false  # 自签证书时设为 true
AUTH_USERNAME=admin
AUTH_PASSWORD=your_admin_password
JWT_SECRET=change-this-to-a-random-string
KEY_ENCRYPT_KEY=change-this-to-32-bytes-hex
